<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dialog_scrollview"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:fadeScrollbars="false"
    android:scrollIndicators="bottom|top">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/l_adbwirelessdialog"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/l_pairing_six_digit"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="start"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:textAppearance="@android:style/TextAppearance.Material.Body1"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WLAN 配对码"
                    android:textDirection="locale"
                    android:textAlignment="viewEnd"
                    android:paddingStart="8dp" />
                <TextView
                    android:textAppearance="@android:style/TextAppearance.Material.Body1"
                    android:textSize="24sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:id="@+id/pairing_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="viewEnd"
                    android:paddingStart="8dp" />
                <TextView
                    android:textAppearance="@android:style/TextAppearance.Material.Body1"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:paddingTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IP 地址和端口"
                    android:textDirection="locale"
                    android:textAlignment="viewEnd"
                    android:paddingStart="8dp" />
                <TextView
                    android:textAppearance="@android:style/TextAppearance.Material.Body1"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:id="@+id/ip_addr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" "
                    android:textDirection="locale"
                    android:textAlignment="viewEnd"
                    android:paddingStart="8dp" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/l_pairing_failed"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="start"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:textAppearance="@android:style/TextAppearance.Material.Body1"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:id="@+id/pairing_failed_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textDirection="locale"
                    android:textAlignment="viewEnd"
                    android:paddingStart="8dp" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/l_qrcode_pairing_failed"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="start"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:textAppearance="@android:style/TextAppearance.Material.Body1"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="无法配对设备。可能是因为二维码不正确，或者设备未连接到同一网络。"
                    android:textDirection="locale"
                    android:textAlignment="viewEnd"
                    android:paddingStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
